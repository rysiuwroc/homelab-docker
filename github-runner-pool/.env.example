# Copy to a deployment-host .env file (never commit that copy).
# These are Portainer stack environment values, not GitHub credentials.
GITHUB_ORG=MRysiukiewicz
RUNNER_GROUP=linux-docker-ci
RUNNER_LABELS=self-hosted,linux,x64,docker

# Numeric group ID of /var/run/docker.sock on the Ubuntu host.
DOCKER_GID=999

# Both values are mandatory build inputs. Keep this pair synchronized when
# updating the runner release; this checksum is for the x64 archive below.
RUNNER_VERSION=2.336.0
RUNNER_SHA256=04cf0be1aff4c3ec3554466c39124ca250e3effd8873bb7e8d68535aa9505d5d

# Absolute path on the Docker host to a root-owned mode-0600 PAT file.
# The file itself is bind-mounted at /run/secrets/github-runner-api-token.
GITHUB_RUNNER_API_TOKEN_FILE=/opt/github-runner-pool/secrets/github-runner-api-token
